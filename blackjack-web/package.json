{
  "name": "blackjack-web",
  "version": "1.0.0",
  "description": "Jeu de Blackjack avec backend Express/TypeScript et frontend Vanilla JS/HTML/CSS",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node src/server.ts",
    "test": "jest",
    "test:unit": "jest",
    "test:e2e": "npx playwright test",
    "katalium:test": "cd katalium && mvn test",
    "katalium:test:headless": "cd katalium && mvn test -Pheadless"
  },
  "keywords": ["blackjack", "express", "typescript", "playwright", "jest"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.4",
    "@types/node": "^25.9.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleFileExtensions": ["ts", "js"],
    "testMatch": ["**/?(*.)+(spec|test).[tj]s?(x)", "**/src/**/game.unit.test.ts", "**/src/**/game.test.fixed.ts"]
  }
}
